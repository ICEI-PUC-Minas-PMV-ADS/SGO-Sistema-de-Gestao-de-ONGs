@{
	ViewData["Title"] = "Cadastro de Doador";
}

<h1 class="cadastro-doador__titulo">Cadastro de Doador</h1>

<form class="formulario-doador">
	<label for="nome">Nome*</label>
	<input type="text" id="nome" class="voluntario__input-padrao" required>

	<label for="email">E-mail</label>
	<input type="email" id="email" class="voluntario__input-padrao" placeholder="exemplo@gmail.com">

	<label for="telefone">Telefone *</label>
	<input type="tel" id="telefone" class="voluntario__input-padrao" required placeholder="(99) 99999-9999">

	<h2 class="doador__preenchimento-obrigatorio">* Campos de preenchimento obrigatório</h2>

	<button type="submit" class="doador__cadastrar">
		<img src="~/img/botão-cadastrar.png" />
		Cadastrar
	</button>
</form>
