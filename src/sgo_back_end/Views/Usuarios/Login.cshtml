@model sgo_back_end.Models.Usuario

@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Login";
}

<section class="login_bg">
    <img src="/img/logo-login-domSolidário.png" class="logo_dom-solidario"/>
    <div class="login__container">
        <div class="login__formulario">
            <img src="/img/logo-sgo.png" />
            <form asp-action="Login">
                <div asp-validation-summary="ModelOnly" class="texto-validacao"></div>
                <div class="login__input">
                    <label asp-for="Nome"><img src="/img/email-login.png"/>E-mail</label>
                    <input asp-for="Nome" class="login__input-padrao" />
                    <span asp-validation-for="Nome" class="texto-validacao"></span>
                </div>
                <div class="login__input">
                    <label asp-for="Senha"><img src="/img/senha-login.png"/>Senha</label>
                    <input asp-for="Senha" type="password" class="login__input-padrao" />
                    <span asp-validation-for="Senha" class="texto-validacao"></span>
                </div>

                <h3> @ViewBag.Message </h3>

                <button type ="submit" class="login__acessar">
                    <img src="/img/acessar-login.png" />
                    Acessar
                </button>

                <a asp-action="Create">Cadastrar</a>
            </form>

            <a class="login_suporte"><img src="/img/suporte-login.png"/>Suporte</a>
        </div>
    </div>
</section>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
